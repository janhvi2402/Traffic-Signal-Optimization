<?xml version="1.0" encoding="UTF-8"?>
<configuration>
    <input>
        <net-file value="../common/network.net.xml"/>
        <route-files value="../common/network.rou.xml"/>
    </input>
    <time>
        <begin value="0"/>
        <end value="3600"/>
        <step-length value="1"/>
    </time>
    <report>
        <verbose value="false"/>
        <no-step-log value="true"/>
        <no-warnings value="true"/>
    </report>
</configuration>