<?xml version="1.0" encoding="UTF-8"?>
<routes>
    <vType id="car" accel="2.6" decel="4.5" sigma="0.5" length="5" minGap="2.5" maxSpeed="13.9"/>

    <!-- Each arm's total probability (~0.65-0.70) matches the per-arm
         totals in the 2-junction network's route file, so a policy
         trained here sees a comparable congestion level to what it
         will face when applied to J1/J2 in the 2-junction test. -->

    <!-- FROM N -->
    <flow id="N_to_S" type="car" from="N_J" to="J_S" begin="0" end="3600" probability="0.25" departLane="0" departSpeed="max"/>
    <flow id="N_to_E" type="car" from="N_J" to="J_E" begin="0" end="3600" probability="0.20" departLane="0" departSpeed="max"/>
    <flow id="N_to_W" type="car" from="N_J" to="J_W" begin="0" end="3600" probability="0.20" departLane="0" departSpeed="max"/>

    <!-- FROM S -->
    <flow id="S_to_N" type="car" from="S_J" to="J_N" begin="0" end="3600" probability="0.25" departLane="0" departSpeed="max"/>
    <flow id="S_to_E" type="car" from="S_J" to="J_E" begin="0" end="3600" probability="0.20" departLane="0" departSpeed="max"/>
    <flow id="S_to_W" type="car" from="S_J" to="J_W" begin="0" end="3600" probability="0.20" departLane="0" departSpeed="max"/>

    <!-- FROM E -->
    <flow id="E_to_W" type="car" from="E_J" to="J_W" begin="0" end="3600" probability="0.25" departLane="0" departSpeed="max"/>
    <flow id="E_to_N" type="car" from="E_J" to="J_N" begin="0" end="3600" probability="0.20" departLane="0" departSpeed="max"/>
    <flow id="E_to_S" type="car" from="E_J" to="J_S" begin="0" end="3600" probability="0.20" departLane="0" departSpeed="max"/>

    <!-- FROM W -->
    <flow id="W_to_E" type="car" from="W_J" to="J_E" begin="0" end="3600" probability="0.25" departLane="0" departSpeed="max"/>
    <flow id="W_to_N" type="car" from="W_J" to="J_N" begin="0" end="3600" probability="0.20" departLane="0" departSpeed="max"/>
    <flow id="W_to_S" type="car" from="W_J" to="J_S" begin="0" end="3600" probability="0.20" departLane="0" departSpeed="max"/>
</routes>
